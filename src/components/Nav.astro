---
import Wordmark from "./Wordmark.astro";
import type { Lang } from "../i18n/ui";
import { useTranslations, getLocalizedPath } from "../i18n/utils";

interface Props { lang?: Lang }
const lang = Astro.props.lang ?? "de";
const t = useTranslations(lang);

const otherLang: Lang = lang === "de" ? "en" : "de";
const switchPath = getLocalizedPath(otherLang, Astro.url.pathname);
---

<header class="nav" id="nav">
  <div class="nav__inner wrap">
    <a class="nav__brand" href="#top" aria-label={t("nav.home.aria")}>
      <Wordmark />
    </a>

    <nav class="nav__links" aria-label="Primary">
      <a href="#events">{t("nav.events")}</a>
      <a href="#how">{t("nav.how")}</a>
      <a href="#rules">{t("nav.rules")}</a>
      <a href="#hall">{t("nav.hall")}</a>
      <a href="#faq">{t("nav.faq")}</a>
    </nav>

    <div class="nav__lang" aria-label="Language">
      <a
        href={lang === "de" ? "#" : switchPath}
        class:list={["nav__lang-opt", { "is-active": lang === "de" }]}
        aria-current={lang === "de" ? "true" : undefined}
      >DE</a>
      <span class="nav__lang-sep" aria-hidden="true">|</span>
      <a
        href={lang === "en" ? "#" : switchPath}
        class:list={["nav__lang-opt", { "is-active": lang === "en" }]}
        aria-current={lang === "en" ? "true" : undefined}
      >EN</a>
    </div>

    <a class="btn nav__cta" href="#signup">{t("nav.cta")}</a>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    transition: background 0.3s var(--ease), border-color 0.3s var(--ease),
      backdrop-filter 0.3s var(--ease);
    border-bottom: 1px solid transparent;
  }
  .nav.scrolled {
    background: rgba(9, 10, 15, 0.78);
    backdrop-filter: blur(14px) saturate(120%);
    border-bottom-color: var(--hairline);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: var(--nav-h);
  }
  .nav__brand {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .nav__links {
    display: flex;
    gap: 1.6rem;
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .nav__links a {
    color: var(--ink-dim);
    position: relative;
    padding-block: 0.3rem;
    white-space: nowrap;
    transition: color 0.2s var(--ease);
  }
  .nav__links a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 2px;
    background: var(--cup-red);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s var(--ease);
  }
  .nav__links a:hover {
    color: var(--off-white);
  }
  .nav__links a:hover::after {
    transform: scaleX(1);
  }

  /* ---- Language picker ---- */
  .nav__lang {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    flex-shrink: 0;
  }
  .nav__lang-opt {
    color: var(--muted);
    padding: 0.25em 0.4em;
    border-radius: 2px;
    transition: color 0.2s var(--ease), background 0.2s var(--ease);
    text-decoration: none;
  }
  .nav__lang-opt:hover {
    color: var(--off-white);
  }
  .nav__lang-opt.is-active {
    color: var(--cup-red);
    background: rgba(230, 57, 70, 0.12);
    pointer-events: none;
  }
  .nav__lang-sep {
    color: var(--hairline-strong);
    font-weight: 300;
    user-select: none;
  }

  .nav__cta {
    padding: 0.6em 1.1em;
    flex-shrink: 0;
  }

  /* ---- Big screens: give the header more presence ---- */
  @media (min-width: 1280px) {
    .nav__inner { gap: 2rem; }
    .nav :global(.wordmark) { font-size: 1.2rem; }
    .nav__links { gap: 2.3rem; font-size: 0.95rem; }
    .nav__lang { font-size: 0.82rem; }
    .nav__cta { font-size: 0.82rem; padding: 0.8em 1.5em; }
  }

  /* ---- Tablet / phone: links collapse, keep the row from overflowing ---- */
  @media (max-width: 920px) {
    .nav__links {
      display: none;
    }
    .nav__lang {
      margin-left: auto;
    }
    .nav__cta {
      margin-left: 0;
    }
  }

  @media (max-width: 560px) {
    .nav__inner { gap: 0.85rem; }
    .nav :global(.wordmark) { font-size: 0.86rem; }
    .nav__lang { gap: 0.25rem; }
    .nav__cta { padding: 0.55em 0.85em; font-size: 0.7rem; letter-spacing: 0.08em; }
  }

  @media (max-width: 400px) {
    .nav__inner { gap: 0.55rem; }
    .nav :global(.wordmark) { font-size: 0.76rem; }
    .nav__lang { font-size: 0.66rem; gap: 0.2rem; }
    .nav__cta { padding: 0.5em 0.7em; font-size: 0.64rem; letter-spacing: 0.06em; }
  }

  /* Very narrow: the hero + banner already carry the sign-up CTA */
  @media (max-width: 330px) {
    .nav__cta { display: none; }
  }
</style>
