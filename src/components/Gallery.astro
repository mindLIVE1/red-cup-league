---
const recaps = [
  { tag: "Night 01 · Kreuzberg", score: "21–18", winner: "Späti Kings", tone: "red", span: "tall" },
  { tag: "Night 02 · Neukölln", score: "Final", winner: "Sudden death", tone: "blue", span: "" },
  { tag: "Bounce of the night", score: "x2", winner: "Mitte Snipers", tone: "warm", span: "" },
  { tag: "Night 03 · F'hain", score: "24 Teams", winner: "Sold out", tone: "dark", span: "wide" },
  { tag: "Crowd shot", score: "01:14", winner: "After the final", tone: "blue", span: "" },
];
---

<section class="section gallery" id="gallery">
  <div class="wrap">
    <div class="gallery__head">
      <p class="eyebrow"><span class="idx">06 /</span> Recap</p>
      <h2 class="section-title">Nights that<br />earned a <span class="red">photo</span></h2>
    </div>

    <div class="gallery__grid">
      {recaps.map((r) => (
        <figure class={`tile tile--${r.tone} ${r.span ? `tile--${r.span}` : ""} reveal`}>
          <span class="tile__score">{r.score}</span>
          <figcaption class="tile__cap">
            <span class="tile__tag">{r.tag}</span>
            <span class="tile__win">{r.winner}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery__head { margin-bottom: 2.6rem; }
  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 190px;
    gap: 1rem;
  }
  .tile {
    position: relative;
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--hairline);
    display: flex;
    align-items: flex-end;
    padding: 1.2rem;
    isolation: isolate;
  }
  .tile::before {
    /* duotone poster wash + grain feel */
    content: "";
    position: absolute;
    inset: 0;
    z-index: -2;
  }
  .tile::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(80% 60% at 70% 20%, rgba(255, 255, 255, 0.12), transparent 60%),
      linear-gradient(to top, rgba(9, 10, 15, 0.85), transparent 70%);
  }
  .tile--red::before { background: linear-gradient(135deg, #e63946, #5a0c14); }
  .tile--blue::before { background: linear-gradient(135deg, #1d4ed8, #0a1838); }
  .tile--warm::before { background: linear-gradient(135deg, #facc15, #7a3b06); }
  .tile--dark::before { background: linear-gradient(135deg, #2a3146, #0d0f17); }

  .tile--tall { grid-row: span 2; }
  .tile--wide { grid-column: span 2; }

  .tile__score {
    position: absolute;
    top: 0.7rem;
    right: 1rem;
    z-index: 1;
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    line-height: 0.8;
    color: rgba(248, 247, 242, 0.92);
    mix-blend-mode: soft-light;
    letter-spacing: 0.02em;
  }
  .tile__cap {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .tile__tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(248, 247, 242, 0.85);
  }
  .tile__win {
    font-family: var(--font-display);
    font-size: 1.25rem;
    text-transform: uppercase;
    color: var(--off-white);
    line-height: 0.95;
  }
  @media (max-width: 720px) {
    .gallery__grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 150px; }
    .tile--wide { grid-column: span 2; }
  }
</style>
