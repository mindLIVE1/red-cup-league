---
import { faqs } from "../data/league";
---

<section class="section faq" id="faq">
  <div class="wrap faq__grid">
    <div class="faq__head">
      <p class="eyebrow"><span class="idx">08 /</span> Before you play</p>
      <h2 class="section-title">Questions<br />from the line</h2>
      <p class="faq__note reveal">Still unsure? Catch us on the night — the table answers everything.</p>
    </div>

    <div class="faq__list">
      {faqs.map((f, i) => (
        <details class="faq__item reveal" name="faq">
          <summary>
            <span class="faq__q">{f.q}</span>
            <span class="faq__icon" aria-hidden="true"></span>
          </summary>
          <p class="faq__a">{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq__grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }
  .faq__head { position: sticky; top: 96px; }
  .faq__note { margin-top: 1.4rem; color: var(--ink-dim); max-width: 28ch; }

  .faq__list { display: flex; flex-direction: column; }
  .faq__item {
    border-top: 1px solid var(--hairline);
  }
  .faq__item:last-child { border-bottom: 1px solid var(--hairline); }
  .faq__item summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.4rem 0;
  }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__q {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 1rem + 1vw, 1.7rem);
    text-transform: uppercase;
    line-height: 1;
    transition: color 0.2s var(--ease);
  }
  .faq__item:hover .faq__q { color: var(--cup-red); }
  .faq__icon {
    position: relative;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }
  .faq__icon::before,
  .faq__icon::after {
    content: "";
    position: absolute;
    background: var(--cup-red);
    transition: transform 0.25s var(--ease), opacity 0.25s var(--ease);
  }
  .faq__icon::before { inset: 8px 0 auto 0; height: 2px; } /* horizontal */
  .faq__icon::after { inset: 0 auto 0 8px; width: 2px; }   /* vertical */
  .faq__item[open] .faq__icon::after { transform: scaleY(0); opacity: 0; }
  .faq__a {
    color: var(--ink-dim);
    font-size: var(--step-0);
    max-width: 56ch;
    padding: 0 0 1.5rem;
    margin: -0.4rem 0 0;
  }

  @media (max-width: 820px) {
    .faq__grid { grid-template-columns: 1fr; }
    .faq__head { position: static; }
  }
</style>
