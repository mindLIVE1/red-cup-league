---
import EventCard from "./EventCard.astro";
import { events } from "../data/league";
---

<section class="section events" id="events">
  <div class="wrap">
    <div class="events__head">
      <div>
        <p class="eyebrow"><span class="idx">02 /</span> Fixtures</p>
        <h2 class="section-title">Upcoming<br /><span class="red">Events</span></h2>
      </div>
      <p class="events__intro reveal">
        The next shots are already lined up. Grab your teammate and secure your
        spot before the bracket fills.
      </p>
    </div>

    <div class="events__grid">
      {events.map((event, i) => <EventCard event={event} featured={i === 0} />)}
    </div>
  </div>
</section>

<style>
  .events {
    /* continuity from the hero: the red glow bleeds up from the cup */
    background: radial-gradient(120% 60% at 38% -10%, rgba(230, 57, 70, 0.1), transparent 60%);
  }
  .events__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem 2rem;
    margin-bottom: 3rem;
  }
  .events__intro {
    max-width: 36ch;
    color: var(--ink-dim);
    font-size: var(--step-1);
  }
  .events__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
    align-items: stretch;
  }
  @media (max-width: 980px) {
    .events__grid { grid-template-columns: 1fr; max-width: 480px; }
  }
</style>
