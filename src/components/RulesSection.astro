---
import { getRules } from "../data/league";
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

interface Props { lang?: Lang }
const lang = Astro.props.lang ?? "de";
const t = useTranslations(lang);
const rules = getRules(lang);
---

<section class="section rules" id="rules">
  <div class="wrap rules__grid">
    <aside class="rules__intro">
      <p class="eyebrow"><span class="idx">04 /</span> {t("rules.eyebrow")}</p>
      <h2 class="section-title">{t("rules.title.line1")}<br /><span class="red">{t("rules.title.line2")}</span><br />{t("rules.title.line3")}</h2>
      <p class="rules__lede reveal">
        {t("rules.lede")}
      </p>
      <p class="rules__stamp" aria-hidden="true">{t("rules.stamp")}</p>
    </aside>

    <ol class="rules__list">
      {rules.map((r, i) => (
        <li class="rules__row reveal">
          <span class="rules__n">R{String(i + 1).padStart(2, "0")}</span>
          <span class="rules__text">{r}</span>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .rules {
    background: var(--dark-gray);
    border-block: 1px solid var(--hairline);
  }
  .rules__grid {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }
  .rules__lede {
    margin-top: 1.6rem;
    color: var(--ink-dim);
    font-size: var(--step-1);
    max-width: 32ch;
  }
  .rules__stamp {
    margin-top: 2rem;
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--cup-red);
    border: 1.5px solid var(--cup-red);
    padding: 0.5em 0.9em;
    border-radius: 3px;
    transform: rotate(-3deg);
    opacity: 0.85;
  }

  .rules__list {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: rule;
  }
  .rules__row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.4rem;
    align-items: baseline;
    padding: 1.3rem 0;
    border-top: 1px solid var(--hairline);
  }
  .rules__row:last-child { border-bottom: 1px solid var(--hairline); }
  .rules__n {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    color: var(--cup-red);
    padding-top: 0.2em;
  }
  .rules__text {
    font-size: var(--step-1);
    line-height: 1.3;
  }
  @media (max-width: 820px) {
    .rules__grid { grid-template-columns: 1fr; }
  }
</style>
