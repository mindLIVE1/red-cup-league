---
import { howItWorks } from "../data/league";
---

<section class="section how" id="how">
  <div class="wrap">
    <div class="how__head">
      <p class="eyebrow"><span class="idx">03 /</span> The Format</p>
      <h2 class="section-title">From the<br /><span class="blue">tower</span> to the cup</h2>
    </div>

    <ol class="how__bracket">
      {howItWorks.map((s) => (
        <li class="how__step reveal">
          <span class="how__n">{s.n}</span>
          <div class="how__body">
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .how__head {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 3rem;
  }
  .how__bracket {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
  }
  .how__step {
    position: relative;
    background: var(--panel);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-lg);
    padding: 2rem 1.6rem;
    min-height: 230px;
    display: flex;
    flex-direction: column;
  }
  /* bracket connectors */
  .how__step:not(:last-child)::after {
    content: "";
    position: absolute;
    right: -1.2rem;
    top: 3.4rem;
    width: 1.2rem;
    height: 2px;
    background: var(--hairline-strong);
  }
  .how__n {
    font-family: var(--font-display);
    font-size: clamp(3rem, 5vw, 4.6rem);
    line-height: 0.8;
    color: transparent;
    -webkit-text-stroke: 1.5px var(--cup-red);
    text-stroke: 1.5px var(--cup-red);
    margin-bottom: 1.4rem;
  }
  .how__step:nth-child(2) .how__n { -webkit-text-stroke-color: var(--varsity-blue); }
  .how__step:nth-child(3) .how__n {
    color: var(--warm);
    -webkit-text-stroke: 0;
  }
  .how__body h3 {
    font-size: var(--step-2);
    margin-bottom: 0.7rem;
    line-height: 0.95;
  }
  .how__body p {
    color: var(--ink-dim);
    font-size: var(--step-0);
  }
  @media (max-width: 820px) {
    .how__bracket { grid-template-columns: 1fr; }
    .how__step { min-height: 0; }
    .how__step:not(:last-child)::after {
      right: auto;
      left: 3rem;
      top: auto;
      bottom: -1.2rem;
      width: 2px;
      height: 1.2rem;
    }
  }
</style>
