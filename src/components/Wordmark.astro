---
// Horizontal varsity lockup. Scales with font-size on .wordmark.
interface Props { class?: string }
const { class: cls = "" } = Astro.props;
---

<span class={`wordmark ${cls}`}>
  <svg class="wordmark__cup" viewBox="0 0 40 44" aria-hidden="true">
    <path d="M7 8 H33 L29 40 H11 Z" fill="var(--cup-red)" />
    <path d="M7 8 H33 L32 16 H8 Z" fill="#fff" opacity="0.16" />
    <ellipse cx="20" cy="8" rx="13" ry="3.4" fill="var(--off-white)" />
    <ellipse cx="20" cy="8" rx="9.5" ry="2.1" fill="var(--cup-red)" opacity="0.55" />
  </svg>
  <span class="wordmark__type">
    <span class="wordmark__line">Red Cup League</span>
    <span class="wordmark__tag">Berlin</span>
  </span>
</span>

<style>
  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
    font-size: 1rem; /* lockup scales from here */
    line-height: 1;
  }
  .wordmark__cup {
    width: 1.45em;
    height: auto;
    flex-shrink: 0;
    filter: drop-shadow(0 2px 8px var(--red-glow));
  }
  .wordmark__type {
    display: flex;
    flex-direction: column;
    gap: 0.18em;
  }
  .wordmark__line {
    font-family: var(--font-display);
    font-size: 1.15em;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    line-height: 0.85;
    color: var(--off-white);
  }
  .wordmark__tag {
    font-family: var(--font-mono);
    font-size: 0.5em;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--varsity-blue);
    padding-left: 0.1em;
  }
</style>
